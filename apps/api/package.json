{
  "name": "api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx ../../scripts/watch-from-root.ts src/index.ts",
    "build": "tsup src/index.ts --out-dir dist --format esm --target node22",
    "typecheck": "tsc --noEmit",
    "check": "pnpm typecheck && pnpm lint",
    "test": "pnpm --dir ../.. exec vitest run apps/api/src --project node --passWithNoTests",
    "lint": "oxlint --config ../../.oxlintrc.json --ignore-path ../../.oxlintignore ."
  },
  "dependencies": {
    "@cs/config": "workspace:*",
    "@cs/core": "workspace:*",
    "@cs/db": "workspace:*",
    "@cs/shared": "workspace:*",
    "@cs/storage": "workspace:*",
    "@hono/node-server": "1.19.13",
    "exceljs": "^4.4.0",
    "hono": "4.12.19",
    "qrcode": "^1.5.4"
  },
  "devDependencies": {
    "@types/qrcode": "^1.5.6"
  }
}
