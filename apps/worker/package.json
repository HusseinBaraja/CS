{
  "name": "worker",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun --env-file=../../.env --watch src/index.ts",
    "build": "bun --env-file=../../.env build src/index.ts --outdir dist",
    "typecheck": "tsc --noEmit",
    "lint": "tsc --noEmit",
    "check": "bun run typecheck && bun run lint",
    "test": "bun --env-file=../../.env test --pass-with-no-tests"
  },
  "dependencies": {
    "@cs/core": "*",
    "@cs/db": "*",
    "@cs/storage": "*"
  }
}

