{
  "name": "worker",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "powershell -NoProfile -ExecutionPolicy Bypass -File ../../scripts/watch-from-root.ps1 src/index.ts",
    "build": "bun --env-file=../../.env build src/index.ts --outdir dist",
    "typecheck": "tsc --noEmit",
    "check": "bun run typecheck",
    "test": "bun --env-file=../../.env test --pass-with-no-tests"
  },
  "dependencies": {
    "@cs/core": "*",
    "@cs/db": "*",
    "@cs/storage": "*"
  }
}

