{
  "name": "bot",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node --watch --env-file-if-exists=../../.env --import tsx src/main.ts",
    "start": "node --env-file-if-exists=../../.env --import tsx src/main.ts",
    "build": "tsup src/main.ts --out-dir dist --format esm --target node22",
    "typecheck": "tsc --noEmit",
    "check": "pnpm typecheck && pnpm lint",
    "test": "pnpm --dir ../.. exec vitest run apps/bot/src --project node --passWithNoTests",
    "lint": "oxlint --config ../../.oxlintrc.json --ignore-path ../../.oxlintignore ."
  },
  "dependencies": {
    "@cs/ai": "workspace:*",
    "@cs/core": "workspace:*",
    "@cs/db": "workspace:*",
    "@cs/rag": "workspace:*",
    "baileys": "7.0.0-rc13",
    "tsx": "^4.20.5"
  },
  "x-dependency-notes": {
    "baileys": "Uses the registry build so pnpm can install without running the GitHub source package prepare step. Advance this pin only after intentionally verifying a newer release in this app."
  }
}
