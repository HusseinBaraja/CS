{
  "name": "bot",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node --watch --env-file=../../.env --import tsx src/main.ts",
    "start": "node --env-file=../../.env --import tsx src/main.ts",
    "dev:bun-experimental": "bun --env-file=../../.env --watch src/index.ts",
    "build": "bun --env-file=../../.env build src/index.ts --outdir dist",
    "typecheck": "tsc --noEmit",
    "lint": "tsc --noEmit",
    "check": "bun run typecheck && bun run lint",
    "test": "bun --env-file=../../.env test --pass-with-no-tests"
  },
  "dependencies": {
    "@cs/ai": "*",
    "@cs/core": "*",
    "@cs/db": "*",
    "@cs/rag": "*",
    "@whiskeysockets/baileys": "https://codeload.github.com/WhiskeySockets/Baileys/tar.gz/refs/heads/master"
  },
  "x-dependency-notes": {
    "@whiskeysockets/baileys": "Uses the official edge GitHub build because the published 7.0.0-rc.9 release still fails companion registration in this app. Revisit once a newer stable release is published and verified."
  },
  "devDependencies": {
    "tsx": "^4.20.5"
  }
}

