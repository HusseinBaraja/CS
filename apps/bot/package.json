{
  "name": "bot",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun --env-file=../../.env --watch src/index.ts",
    "build": "bun --env-file=../../.env build src/index.ts --outdir dist",
    "typecheck": "tsc --noEmit",
    "lint": "tsc --noEmit",
    "check": "bun run typecheck && bun run lint",
    "test": "bun --env-file=../../.env test --pass-with-no-tests"
  },
  "dependencies": {
    "@cs/ai": "*",
    "@cs/core": "*",
    "@cs/rag": "*",
    "@whiskeysockets/baileys": "7.0.0-rc.9"
  },
  "x-dependency-notes": {
    "@whiskeysockets/baileys": "Pinned to 7.0.0-rc.9 because no stable 7.x release is published as of 2026-03-06. Replace with stable 7.x when available."
  }
}

