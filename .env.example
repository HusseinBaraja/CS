# ── General ──────────────────────────────────────────
NODE_ENV=development
LOG_LEVEL=debug

# ── API ──────────────────────────────────────────────
API_PORT=3000
API_KEY=

# ── Convex ───────────────────────────────────────────
CONVEX_URL=                    # Auto-set by `npx convex dev`

# ── AI Providers ─────────────────────────────────────
AI_PROVIDER=deepseek           # deepseek | gemini | groq
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
GEMINI_API_KEY=
GROQ_API_KEY=

# ── Embeddings ───────────────────────────────────────
EMBEDDING_API_KEY=             # Gemini key used for 768d embeddings

# ── Cloudflare R2 ────────────────────────────────────
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_PUBLIC_URL=                 # Public bucket URL for serving files
