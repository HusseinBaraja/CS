# ── General ──────────────────────────────────────────
NODE_ENV=development
LOG_LEVEL=debug
BACKUP_DIR=backups
BACKUP_RETENTION_COUNT=5
LOG_DIR=logs
LOG_RETENTION_DAYS=14

# ── API ──────────────────────────────────────────────
API_PORT=3000
API_KEY=
API_CORS_ORIGINS=*
API_RATE_LIMIT_MAX=60
API_RATE_LIMIT_WINDOW_MS=60000

# ── Convex ───────────────────────────────────────────
CONVEX_ADMIN_KEY=
CONVEX_URL=

# ── Cloudflare R2 ────────────────────────────────────
R2_BUCKET_NAME=
R2_ENDPOINT=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
