{
  "$schema": "./package.schema.json",
  "name": "cs",
  "private": true,
  "packageManager": "pnpm@10.25.0",
  "workspaces": [
    "apps/*",
    "packages/*",
    "convex"
  ],
  "scripts": {
    "dev": "tsx scripts/dev-session-log.ts",
    "web": "pnpm dev:web",
    "dev:api": "tsx scripts/dev-session-log.ts --filter=api",
    "dev:bot": "tsx scripts/dev-session-log.ts --filter=api --filter=bot",
    "dev:web": "turbo run dev --filter=web",
    "dev:worker": "tsx scripts/dev-session-log.ts --filter=worker",
    "build": "turbo run build",
    "build:web": "turbo run build --filter=web",
    "typecheck": "turbo run typecheck",
    "lint": "pnpm lint:root && turbo run lint",
    "test": "pnpm test:root && turbo run test",
    "test:root": "vitest run scripts --passWithNoTests",
    "check:ai": "tsx scripts/ai-provider-check.ts",
    "check:root": "pnpm test:root",
    "issue:diagram": "tsx scripts/generate-agent-mermaid.ts",
    "test:convex": "vitest run --config convex/vitest.config.ts",
    "check": "pnpm check:root && turbo run check",
    "preview:web": "pnpm --dir apps/web preview",
    "generate": "convex codegen",
    "seed": "pnpm --dir apps/cli seed",
    "backup": "pnpm --dir apps/cli backup",
    "ci": "pnpm check:root && turbo run ci",
    "lint:root": "oxlint --config .oxlintrc.json --ignore-path .oxlintignore scripts"
  },
  "dependencies": {
    "convex": "1.32.0"
  },
  "devDependencies": {
    "@edge-runtime/vm": "^5.0.0",
    "@types/node": "^24.10.2",
    "oxlint": "^1.61.0",
    "tsx": "^4.20.5",
    "tsup": "^8.5.1",
    "turbo": "^2.9.3",
    "typescript": "5.9.3",
    "vite": "8.0.5",
    "vitest": "^4.1.6"
  }
}
