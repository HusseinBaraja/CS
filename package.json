{
  "$schema": "./package.schema.json",
  "name": "cs",
  "private": true,
  "packageManager": "bun@1.3.9",
  "workspaces": [
    "apps/*",
    "packages/*",
    "convex"
  ],
  "scripts": {
    "dev": "bun scripts/dev-session-log.ts",
    "web": "bun run dev:web",
    "dev:api": "bun scripts/dev-session-log.ts --filter=api",
    "dev:bot": "bun scripts/dev-session-log.ts --filter=api --filter=bot",
    "dev:web": "turbo run dev --filter=web",
    "dev:worker": "bun scripts/dev-session-log.ts --filter=worker",
    "build": "turbo run build",
    "build:web": "turbo run build --filter=web",
    "typecheck": "turbo run typecheck",
    "lint": "turbo run lint",
    "test": "bun run test:root && turbo run test",
    "test:root": "bun test ./scripts --pass-with-no-tests",
    "check:ai": "bun scripts/ai-provider-check.ts",
    "check:modularity": "bun scripts/modularity-policy.ts",
    "check:root": "bun run check:modularity",
    "issue:diagram": "bun scripts/generate-agent-mermaid.ts",
    "test:convex": "bun x vitest run --config convex/vitest.config.ts",
    "check": "bun run check:root && turbo run check",
    "preview:web": "bun --cwd apps/web run preview",
    "generate": "bunx convex codegen",
    "seed": "bun run --cwd apps/cli seed",
    "backup": "bun run --cwd apps/cli backup",
    "ci": "bun run check:root && bun run test:root && turbo run ci"
  },
  "dependencies": {
    "convex": "1.32.0"
  },
  "devDependencies": {
    "@edge-runtime/vm": "^5.0.0",
    "@types/bun": "1.3.9",
    "turbo": "^2.9.3",
    "typescript": "5.9.3",
    "vite": "8.0.5",
    "vitest": "^4.0.18"
  }
}
