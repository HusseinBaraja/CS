{
  "$schema": "./package.schema.json",
  "name": "cs",
  "private": true,
  "packageManager": "bun@1.3.9",
  "workspaces": [
    "apps/*",
    "packages/*",
    "convex"
  ],
  "scripts": {
    "dev": "turbo run dev --parallel",
    "dev:api": "turbo run dev --filter=api",
    "dev:bot": "turbo run dev --filter=bot",
    "dev:worker": "turbo run dev --filter=worker",
    "build": "turbo run build",
    "typecheck": "turbo run typecheck",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "test:convex": "bun x vitest run",
    "check": "turbo run check",
    "generate": "turbo run generate",
    "ci": "turbo run ci"
  },
  "dependencies": {
    "convex": "1.32.0"
  },
  "devDependencies": {
    "@edge-runtime/vm": "^5.0.0",
    "@types/bun": "1.3.9",
    "convex-test": "^0.0.41",
    "turbo": "2.8.12",
    "typescript": "5.9.3",
    "vite": "^7.3.1",
    "vitest": "^4.0.18"
  }
}