{
  "name": "@cs/core",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "scripts": {
    "dev": "tsx ../../scripts/watch-from-root.ts src/index.ts",
    "build": "tsup src/index.ts --out-dir dist --format esm --target node22",
    "typecheck": "tsc --noEmit",
    "check": "pnpm typecheck && pnpm lint",
    "test": "pnpm --dir ../.. exec vitest run packages/core/src --project node --passWithNoTests",
    "lint": "oxlint --config ../../.oxlintrc.json --ignore-path ../../.oxlintignore ."
  },
  "dependencies": {
    "@cs/config": "workspace:*",
    "@cs/shared": "workspace:*",
    "pino": "10.3.1",
    "pino-pretty": "13.1.3"
  }
}
