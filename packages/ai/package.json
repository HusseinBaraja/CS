{
  "name": "@cs/ai",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./embeddings": "./src/embeddings/index.ts"
  },
  "scripts": {
    "dev": "bun ../../scripts/watch-from-root.ts src/index.ts",
    "build": "bun build src/index.ts --outdir dist",
    "typecheck": "tsc --noEmit",
    "check": "bun run typecheck && bun run lint",
    "test": "bun test --pass-with-no-tests",
    "lint": "oxlint --config ../../.oxlintrc.json --ignore-path ../../.oxlintignore ."
  },
  "dependencies": {
    "@cs/config": "*",
    "@cs/shared": "*",
    "@google/genai": "1.43.0",
    "groq-sdk": "0.37.0",
    "openai": "6.25.0"
  }
}
