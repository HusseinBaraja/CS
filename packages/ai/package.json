{
  "name": "@cs/ai",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./embeddings": "./src/embeddings/index.ts"
  },
  "scripts": {
    "dev": "bun --watch src/index.ts",
    "build": "bun build src/index.ts --outdir dist",
    "typecheck": "tsc --noEmit",
    "check": "bun run typecheck",
    "test": "bun test --pass-with-no-tests"
  },
  "dependencies": {
    "@cs/config": "*",
    "@cs/shared": "*",
    "@google/genai": "1.43.0",
    "groq-sdk": "0.37.0",
    "openai": "6.25.0"
  }
}

