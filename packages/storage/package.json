{
  "name": "@cs/storage",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "scripts": {
    "dev": "tsx ../../scripts/watch-from-root.ts src/index.ts",
    "build": "tsup src/index.ts --out-dir dist --format esm --target node22",
    "typecheck": "tsc --noEmit",
    "lint": "oxlint --config ../../.oxlintrc.json --ignore-path ../../.oxlintignore .",
    "check": "pnpm typecheck && pnpm lint",
    "test": "pnpm --dir ../.. exec vitest run packages/storage/src --project node --passWithNoTests"
  },
  "dependencies": {
    "@cs/config": "workspace:*",
    "@cs/shared": "workspace:*",
    "@aws-sdk/client-s3": "^3.953.0",
    "@aws-sdk/s3-request-presigner": "^3.953.0"
  }
}
